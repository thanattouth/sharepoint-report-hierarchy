# Single-tenant Entra interactive authentication for the report web application.
# Store client/session secrets only as Sites server secrets; never use NEXT_PUBLIC_*.
ENTRA_AUTH_TENANT_ID=
ENTRA_AUTH_CLIENT_ID=
ENTRA_AUTH_CLIENT_SECRET=
# Base64url without padding; must decode to exactly 32 random bytes.
ENTRA_AUTH_SESSION_SECRET=
# Comma-separated exact origins. HTTPS is required outside localhost.
ENTRA_AUTH_ALLOWED_ORIGINS=https://sharepoint-sensitivity-report-hierarchy.uzumaki1747.chatgpt.site,http://localhost:3000
ENTRA_AUTH_SESSION_HOURS=8
