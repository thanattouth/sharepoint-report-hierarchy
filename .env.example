# Scanner-only configuration. Never expose these values through NEXT_PUBLIC_*.
SCANNER_AUTH_MODE=default
SCANNER_TENANT_ID=
SCANNER_MANAGED_IDENTITY_CLIENT_ID=

# Use client-secret only for an explicitly approved local P4 pilot.
SCANNER_CLIENT_ID=
SCANNER_CLIENT_SECRET=

# P4 is intentionally restricted to exactly one non-production Graph Site ID.
SCANNER_ALLOWED_SITE_ID=
SCANNER_SECRET_LABEL_IDS=
SCANNER_MAX_CONCURRENCY=4
SCANNER_MAX_RETRIES=3
