# Scanner-only configuration. Never expose these values through NEXT_PUBLIC_*.
SCANNER_AUTH_MODE=default
SCANNER_TENANT_ID=
SCANNER_MANAGED_IDENTITY_CLIENT_ID=

# Use client-secret only for an explicitly approved local P4 pilot.
SCANNER_CLIENT_ID=
SCANNER_CLIENT_SECRET=

# P4 is intentionally restricted to exactly one non-production Graph Site ID.
SCANNER_ALLOWED_SITE_ID=
# Comma-separated Purview label GUIDs included in the report, for example Confidential and Secret.
SCANNER_REPORTABLE_LABEL_IDS=
# Optional JSON map for display only. Inclusion decisions always use immutable label IDs.
# Example: {"00000000-0000-4000-8000-000000000001":"Confidential","00000000-0000-4000-8000-000000000002":"Secret"}
SCANNER_LABEL_DISPLAY_NAMES_JSON=
SCANNER_MAX_CONCURRENCY=4
SCANNER_MAX_RETRIES=3

# Explicit diagnostic-only bounds for a controlled P4 extraction. Never widen silently.
P4_PILOT_LIBRARY_NAMES=
P4_PILOT_MAX_FILES_PER_LIBRARY=20
P4_PILOT_MAX_DELTA_PAGES_PER_LIBRARY=10

# Azure Table cache. Use a customer-owned isolated account and token-based access.
AZURE_STORAGE_ACCOUNT_NAME=
# Azure tenant that owns the storage subscription. This can differ from SCANNER_TENANT_ID.
AZURE_STORAGE_TENANT_ID=
# azure-cli is only for an approved local pilot; use managed-identity for hosted workers.
AZURE_TABLE_AUTH_MODE=managed-identity
AZURE_STORAGE_MANAGED_IDENTITY_CLIENT_ID=
# Optional overrides; defaults match infra/azure-table-pilot/main.bicep.
AZURE_TABLE_ENDPOINT=
AZURE_TABLE_INVENTORY_NAME=SensitivityInventory
AZURE_TABLE_SCAN_RUN_NAME=SensitivityScanRuns
AZURE_TABLE_DELTA_STATE_NAME=SensitivityDeltaState
AZURE_TABLE_SITE_SUMMARY_NAME=SiteLabelSummary

# Report cache selection. Fixture remains the safe default for builds/tests.
REPORT_DATA_SOURCE=fixture
# Required only for azure-table mode. These are report settings, not Graph credentials.
REPORT_CACHE_TENANT_ID=
REPORT_REPORTABLE_LABEL_IDS=
REPORT_PILOT_SITE_ID=
REPORT_PILOT_SITE_NAME=
REPORT_PILOT_SITE_HOSTNAME=
REPORT_PILOT_SITE_PATH=
REPORT_PILOT_SITE_NODE_ID=
REPORT_MAX_DETAIL_SITES=25
REPORT_NEXT_SCHEDULED_SCAN=
REPORT_API_BASE_URL=
REPORT_API_FUNCTION_KEY=
REPORT_API_TIMEOUT_MS=10000

# P6 Azure report API deployment. Keep role assignment explicit because Contributor cannot grant RBAC.
P6_AZURE_SUBSCRIPTION_ID=
P6_AZURE_RESOURCE_GROUP=
P6_AZURE_LOCATION=
P6_ASSIGN_MANAGED_IDENTITY_ROLES=false
REPORT_PILOT_ALLOWED_UPNS=
