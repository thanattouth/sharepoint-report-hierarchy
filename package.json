{
  "name": "sharepoint-sensitivity-label-report",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext dev",
    "build": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext build",
    "start": "WRANGLER_LOG_PATH=.wrangler/wrangler.log vinext start",
    "test": "npm run test:unit && npm run build && node --test tests/rendered-html.test.mjs",
    "test:unit": "node --import tsx --test tests/*.test.ts",
    "env:split:dry-run": "node --import tsx scripts/split-legacy-env.ts",
    "env:split:apply": "node --import tsx scripts/split-legacy-env.ts --apply",
    "p4:check": "node --import tsx scripts/p4-connection-check.ts",
    "p4:bounded": "node --import tsx scripts/p4-bounded-pilot.ts",
    "p5:persist-bounded": "node --import tsx scripts/p5-persist-bounded-pilot.ts",
    "p5:persist-bounded:local": "node --import tsx scripts/run-env-profile.ts p5-cache -- scripts/p5-persist-bounded-pilot.ts",
    "p5:materialize-summary": "node --import tsx scripts/p5-materialize-site-summary.ts",
    "p5:materialize-summary:local": "node --import tsx scripts/run-env-profile.ts p5-cache -- scripts/p5-materialize-site-summary.ts",
    "p5:verify-report-cache:local": "node --import tsx scripts/run-env-profile.ts p6-report -- scripts/p5-report-cache-check.ts",
    "p5:scanner:build": "npm --prefix services/scheduled-scanner run build",
    "p5:scanner:package": "node scripts/p5-package-scheduled-scanner.mjs",
    "p5:scanner:what-if:local": "node --import tsx scripts/run-env-profile.ts p5-scanner -- scripts/p5-deploy-scheduled-scanner.ts --what-if",
    "p5:scanner:deploy:local": "node --import tsx scripts/run-env-profile.ts p5-scanner -- scripts/p5-deploy-scheduled-scanner.ts --deploy",
    "p5:scanner:publish:local": "node --import tsx scripts/run-env-profile.ts p5-scanner -- scripts/p5-publish-scheduled-scanner.ts",
    "p5:scanner:seed-site:local": "node --import tsx scripts/run-env-profile.ts p5-scanner -- scripts/p5-seed-scanner-site.ts",
    "p5:scanner:federate:local": "node --import tsx scripts/run-env-profile.ts p5-scanner -- scripts/p5-configure-scanner-federation.ts",
    "p5:scanner:run-now-check:local": "node --import tsx scripts/run-env-profile.ts p5-scanner -- scripts/p5-run-now-check.ts",
    "p5:scanner:discover-sites:local": "node --import tsx scripts/run-env-profile.ts p5-scanner -- scripts/p5-discover-tenant-sites.ts",
    "p5:scanner:count-files:local": "node --import tsx scripts/run-env-profile.ts p5-scanner -- scripts/p5-count-tenant-files.ts",
    "p5:scanner:build-candidate-manifest:local": "node --import tsx scripts/run-env-profile.ts p5-scanner -- scripts/p5-build-candidate-manifest.ts",
    "p5:scanner:review-wave-1:local": "node --import tsx scripts/run-env-profile.ts p5-scanner -- scripts/p5-review-wave-one.ts",
    "p5:scanner:exclude-candidates:local": "node --import tsx scripts/run-env-profile.ts p5-scanner -- scripts/p5-exclude-baseline-candidates.ts --apply",
    "p5:scanner:activate-wave-1:local": "node --import tsx scripts/run-env-profile.ts p5-scanner -- scripts/p5-activate-wave-one.ts --apply",
    "p5:scanner:run-wave-1:local": "node --import tsx scripts/run-env-profile.ts p5-scanner -- scripts/p5-run-wave-one.ts",
    "p5:scanner:queue-status:local": "node --import tsx scripts/run-env-profile.ts p5-scanner -- scripts/p5-queue-status.ts",
    "p5:scanner:audit-wave-1:local": "node --import tsx scripts/run-env-profile.ts p5-scanner -- scripts/p5-audit-wave-one.ts",
    "p5:scanner:skip-baseline-site:local": "node --import tsx scripts/run-env-profile.ts p5-scanner -- scripts/p5-skip-baseline-site.ts --apply",
    "p6:api:build": "npm --prefix services/report-cache-api run build",
    "p6:api:package": "node scripts/p6-package-report-api.mjs",
    "p6:api:publish:local": "node --import tsx scripts/run-env-profile.ts p6-report -- scripts/p6-publish-report-api.ts",
    "p6:api:what-if:local": "node --import tsx scripts/run-env-profile.ts p6-report -- scripts/p6-deploy-report-api.ts --what-if",
    "p6:api:deploy:local": "node --import tsx scripts/run-env-profile.ts p6-report -- scripts/p6-deploy-report-api.ts --deploy",
    "p6:map-completed-baseline:local": "node --import tsx scripts/run-env-profile.ts p6-mapping -- scripts/p6-map-completed-baseline.ts --apply",
    "p6:map-site:local": "node --import tsx scripts/run-env-profile.ts p6-mapping -- scripts/p6-map-site.ts --apply",
    "p6:api:check-multi-site:local": "node --import tsx scripts/run-env-profile.ts p6-report -- scripts/p6-check-report-api.ts",
    "p7:config:migrate:local": "node --import tsx scripts/run-env-profile.ts p7-configuration -- scripts/p7-migrate-configuration.ts",
    "p7:config:migrate:apply:local": "node --import tsx scripts/run-env-profile.ts p7-configuration -- scripts/p7-migrate-configuration.ts --apply",
    "p7:admin:build": "npm --prefix services/configuration-admin-api run build",
    "p7:admin:package": "node scripts/p7-package-configuration-admin-api.mjs",
    "p7:admin:what-if:local": "node --import tsx scripts/run-env-profile.ts p7-configuration -- scripts/p7-deploy-configuration-admin-api.ts --what-if",
    "p7:admin:deploy:local": "node --import tsx scripts/run-env-profile.ts p7-configuration -- scripts/p7-deploy-configuration-admin-api.ts --deploy",
    "p7:admin:publish:local": "node --import tsx scripts/run-env-profile.ts p7-configuration -- scripts/p7-publish-configuration-admin-api.ts",
    "p7:admin:check:local": "node --import tsx scripts/run-env-profile.ts p7-configuration -- scripts/p7-check-configuration-admin-api.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ignore-pattern dist --ignore-pattern .next"
  },
  "dependencies": {
    "@azure/data-tables": "^13.3.2",
    "@azure/identity": "^4.13.1",
    "next": "16.2.6",
    "openid-client": "^6.8.4",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.44.0",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitejs/plugin-rsc": "0.5.26",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "react-server-dom-webpack": "19.2.6",
    "tailwindcss": "4.2.1",
    "tsx": "4.22.1",
    "typescript": "5.9.3",
    "vinext": "0.0.50",
    "vite": "^8.1.4",
    "wrangler": "^4.102.0"
  },
  "type": "module"
}
