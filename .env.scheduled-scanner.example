# Hosted scanner runtime settings. Hosted authentication uses managed/workload identity.
SCANNER_AUTH_MODE=managed-identity
SCANNER_MANAGED_IDENTITY_CLIENT_ID=
SCANNER_HOST_MANAGED_IDENTITY_CLIENT_ID=
SCANNER_HOST_STORAGE_ACCOUNT_NAME=
SCANNER_JOB_QUEUE_NAME=site-scan-jobs
SCANNER_BASELINE_WINDOW_OPEN=false
SCANNER_NIGHTLY_SCHEDULE=0 0 18 * * *
SCANNER_RECONCILIATION_SCHEDULE=0 0 19 * * 6
